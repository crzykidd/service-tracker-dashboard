{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh release *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(docker compose *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(python -c *)",
      "Bash(pip install *)",
      "Bash(alembic *)",
      "Bash(flask *)",
      "Bash(curl -s http://localhost:8815/*)",
      "Bash(curl -s http://localhost:8815/api/*)",
      "Bash(git config *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "mcp__vexp__run_pipeline"
    ],
    "additionalDirectories": [
      "C:\\projects\\service-tracker-dashboard\\alembic\\versions"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Regex",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/vexp-guard.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
